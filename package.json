{
  "name": "forma-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "copy-ort-wasm": "cp node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.* public/",
    "predev": "npm run copy-ort-wasm",
    "dev": "vite",
    "prebuild": "npm run copy-ort-wasm",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.1",
    "dagre": "^0.8.5",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
